{
  "manifest_version": 3,
  "name": "AI Chat Bookmarks",
  "version": "1.0",
  "description": "Instantly bookmark and navigate any section of your AI chats on Claude, ChatGPT, Gemini and Grok.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://x.com/i/grok*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
